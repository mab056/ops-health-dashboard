{
  "name": "ops-health-dashboard/ops-health-dashboard",
  "description": "Production-grade WordPress health monitoring with TDD and strict security",
  "type": "wordpress-plugin",
  "license": "GPL-3.0-or-later",
  "authors": [
    {
      "name": "Ops Team",
      "email": "dev@example.com"
    }
  ],
  "require": {
    "php": ">=7.4"
  },
  "require-dev": {
    "phpunit/phpunit": "^9.5",
    "yoast/phpunit-polyfills": "^2.0",
    "squizlabs/php_codesniffer": "^3.8",
    "wp-coding-standards/wpcs": "^3.0",
    "phpcompatibility/phpcompatibility-wp": "^2.1",
    "brain/monkey": "^2.6",
    "mockery/mockery": "^1.5"
  },
  "autoload": {
    "psr-4": {
      "OpsHealthDashboard\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "OpsHealthDashboard\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit --testsuite=unit && phpunit --testsuite=integration",
    "test:all": "phpunit --testsuite=unit && phpunit --testsuite=integration",
    "test:unit": "phpunit --testsuite=unit",
    "test:integration": "phpunit --testsuite=integration",
    "test:coverage": "XDEBUG_MODE=coverage phpunit --testsuite=unit --coverage-text --coverage-clover=coverage/clover-unit.xml && XDEBUG_MODE=coverage phpunit --testsuite=integration --coverage-text --coverage-clover=coverage/clover-integration.xml",
    "test:coverage:unit": "XDEBUG_MODE=coverage phpunit --testsuite=unit --coverage-text --coverage-clover=coverage/clover-unit.xml",
    "test:coverage:integration": "XDEBUG_MODE=coverage phpunit --testsuite=integration --coverage-text --coverage-clover=coverage/clover-integration.xml",
    "phpcs": "phpcs",
    "phpcbf": "phpcbf",
    "install-wp-tests": "bash bin/install-wp-tests.sh wordpress_test root '' localhost latest",
    "test:matrix": "bash bin/test-matrix.sh"
  },
  "config": {
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true
    },
    "platform": {
      "php": "7.4"
    }
  }
}
